# ─────────────────────────────────────────────
#  Credenciales y entorno - NO subir a Git
# ─────────────────────────────────────────────

# URL de la aplicación (ajustar si cambia IP)
APP_URL=http://10.2.1.81/Account/Login

# Credenciales de acceso al sistema
APP_USUARIO=tu_usuario
APP_PASSWORD=tu_contraseña

# Ruta de descarga temporal (dejar vacío para usar input_raw/ del proyecto)
RUTA_DESCARGA=

# Modo del navegador: "visible" | "headless"
MODO_NAVEGADOR=visible

# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# VPN — FortiClient IPSec
VPN_NAME=VPN POSE IP SEC
VPN_USER=rrivarola
VPN_PASSWORD=
VPN_TARGET_IP=10.2.1.81

# ─── ETL Pipeline ─────────────────────────────────────────────────────────────

# Base de datos origen/destino (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestion_comp
DB_USER=etl_user
DB_PASSWORD=

# API externa de reportes
API_REPORTES_URL=http://localhost:8080/api
API_REPORTES_TOKEN=

# Formato de salida de reportes ETL: xlsx | csv
REPORTE_FORMATO=xlsx

# Tamaño de lote para carga en BD
ETL_BATCH_SIZE=1000

# ─── Rango de análisis ────────────────────────────────────────────────────────

# Fecha de inicio fija del período analizado por Cuenta Corriente (DD/MM/YYYY)
# Cambiar cuando se quiera ampliar el rango histórico.
CC_FECHA_DESDE=01/04/2026

# ─── Retención de archivos ────────────────────────────────────────────────────
RETENCION_REPORTES_DIAS=90
RETENCION_LOGS_DIAS=30

# ─── Rutas de archivos fuente (FAT32 / M2) ───────────────────────────────────
# Cuando FAT32 está montada o M2 accesible, apuntar aquí.
# Si está vacío, el script usa input_raw/ local como fallback automático.
# Ejemplo con FAT32 montada:
# FAT32_COMMON_DIR=/media/richard/FAT32/report_gerencias/input_raw/common
FAT32_COMMON_DIR=

# Ruta local al repo Pose_DataPipeline según la máquina
# M1 (Linux):  /home/richard/Dev/Pose_DataPipeline
# M2 (Windows): C:\Dev\Pose_DataPipeline
DATAPIPELINE_DIR=
